@page "/admin/movies/new"
@page "/admin/movies/{Id:int}/edit"
@attribute [Authorize(Roles = "Admin")]
@using RetroVHS.Shared.DTOs.Movies
@using RetroVHS.Shared.DTOs.Genres
@using RetroVHS.Shared.DTOs.Persons
@using RetroVHS.Shared.DTOs.ProductionCompanies
@using RetroVHS.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@inject IAdminClient AdminClient
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(Id.HasValue ? "Redigera film" : "Lägg till film")</PageTitle>

<div class="movie-form-page">
    <a href="/admin/movies" class="admin-back-link">← Filmlistan</a>
    <h1 class="section-title">@(Id.HasValue ? "✏️ Redigera film" : "➕ Lägg till film")</h1>

    @if (isLoading)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="movie-form-grid">

            <div class="movie-form-field">
                <label>Titel *</label>
                <input type="text" @bind="title" @onblur="() => _tTitle = true" placeholder="Filmens titel" />
                @if (ShowTitle && string.IsNullOrWhiteSpace(title))
                { <span class="validation-message">Titel krävs.</span> }
            </div>

            <div class="movie-form-field">
                <label>Utgivningsår *</label>
                <input type="number" @bind="releaseYear" @onblur="() => _tYear = true" min="1888" max="@DateTime.Now.Year" />
                @if (ShowYear && (releaseYear < 1888 || releaseYear > DateTime.Now.Year))
                { <span class="validation-message">Ange ett giltigt år (1888–@DateTime.Now.Year).</span> }
            </div>

            <div class="movie-form-field">
                <label>Längd (minuter) *</label>
                <input type="number" @bind="durationMinutes" @onblur="() => _tDuration = true" min="1" max="600" />
                @if (ShowDuration && (durationMinutes < 1 || durationMinutes > 600))
                { <span class="validation-message">Filmlängden måste vara mellan 1 och 600 minuter.</span> }
            </div>

            <div class="movie-form-field">
                <label>Hyrespris (kr) *</label>
                <input type="number" @bind="rentalPrice" @onblur="() => _tPrice = true" min="0.01" max="999.99" step="0.01" />
                @if (ShowPrice && (rentalPrice < 0.01m || rentalPrice > 999.99m))
                { <span class="validation-message">Priset måste vara mellan 0,01 och 999,99 kr.</span> }
            </div>

            <div class="movie-form-field">
                <label>Lagersaldo</label>
                <input type="number" @bind="stockQuantity" @onblur="() => _tStock = true" min="0" max="10000" />
                @if (ShowStock && (stockQuantity < 0 || stockQuantity > 10000))
                { <span class="validation-message">Lagersaldo måste vara mellan 0 och 10 000.</span> }
            </div>

            <div class="movie-form-field">
                <label>Tillgänglighetsstatus</label>
                <select @bind="availabilityStatus">
                    @foreach (var s in Enum.GetValues<MovieAvailabilityStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="movie-form-field">
                <label>Poster-URL</label>
                <input type="text" @bind="posterUrl" placeholder="https://..." />
            </div>

            <div class="movie-form-field">
                <label>Trailer-URL (YouTube)</label>
                <input type="text" @bind="trailerUrl" placeholder="https://youtube.com/..." />
            </div>

            <div class="movie-form-field">
                <label>Språk</label>
                <input type="text" @bind="language" placeholder="t.ex. English" />
            </div>

            <div class="movie-form-field">
                <label>Land</label>
                <input type="text" @bind="country" placeholder="t.ex. USA" />
            </div>

            <div class="movie-form-field full-width row-inline">
                <input type="checkbox" id="featured" @bind="isFeatured" />
                <label for="featured" class="form-label-inline">Utvald (visas på startsidan)</label>
            </div>

            <div class="movie-form-field full-width">
                <label>Synopsis *</label>
                <textarea @bind="synopsis" @onblur="() => _tSynopsis = true" rows="4" maxlength="1000" placeholder="Filmens beskrivning..."></textarea>
                @if (ShowSynopsis && string.IsNullOrWhiteSpace(synopsis))
                { <span class="validation-message">Synopsis krävs.</span> }
            </div>

            <div class="movie-form-field full-width">
                <label>Genres</label>
                <div class="genre-tag-list">
                    @foreach (var g in allGenres)
                    {
                        var genre = g;
                        <span class="genre-form-tag @(selectedGenreIds.Contains(genre.Id) ? "selected" : "")"
                              @onclick="() => ToggleGenre(genre.Id)">
                            @genre.Name
                        </span>
                    }
                </div>
                <div class="new-genre-row">
                    <input type="text" @bind="newGenreName" @bind:event="oninput"
                           placeholder="Ny genre..." class="input-flex" />
                    <button type="button" class="btn-add-row"
                            @onclick="CreateGenreAsync"
                            disabled="@(string.IsNullOrWhiteSpace(newGenreName))">
                        + Lägg till genre
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(genreError))
                { <span class="validation-message">@genreError</span> }
            </div>

            <div class="movie-form-field full-width">
                <label>Produktionsbolag</label>
                <div class="person-search-row">
                    <div class="person-row-inputs">
                        <input type="text" placeholder="Sök eller skriv nytt produktionsbolag..."
                               value="@companySearchText"
                               @oninput="OnCompanyInput"
                               @onfocus="() => showCompanyDropdown = true"
                               class="input-flex" />
                        @if (selectedCompanyId.HasValue || !string.IsNullOrWhiteSpace(companySearchText))
                        {
                            <button type="button" class="btn-remove-row" @onclick="ClearCompany">✕</button>
                        }
                    </div>
                    @if (showCompanyDropdown && !string.IsNullOrWhiteSpace(companySearchText))
                    {
                        <div class="person-search-result-dropdown">
                            @foreach (var c in filteredCompanies)
                            {
                                var company = c;
                                <div class="person-result-item" @onmousedown="() => SelectCompany(company)">@c.Name</div>
                            }
                            @if (!filteredCompanies.Any(c => c.Name.Equals(companySearchText, StringComparison.OrdinalIgnoreCase)))
                            {
                                <div class="person-result-item create-new-item" @onmousedown="CreateCompanyAsync">➕ Skapa "@companySearchText"</div>
                            }
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(companyError))
                { <span class="validation-message">@companyError</span> }
            </div>

            <div class="movie-form-field full-width">
                <label>Regissörer</label>
                @for (int i = 0; i < directors.Count; i++)
                {
                    var idx = i;
                    <div class="person-search-row">
                        <div class="person-row-inputs">
                            <input type="text" placeholder="Sök person..."
                                   value="@directors[idx].DisplayName"
                                   @oninput="e => OnPersonSearchInput(e, idx, directors)"
                                   class="input-flex" />
                            <button type="button" class="btn-remove-row" @onclick="() => directors.RemoveAt(idx)">✕</button>
                        </div>
                        @if (directors[idx].ShowDropdown && directors[idx].SearchResults.Count > 0)
                        {
                            <div class="person-search-result-dropdown">
                                @foreach (var p in directors[idx].SearchResults)
                                {
                                    var person = p;
                                    <div class="person-result-item" @onmousedown="() => SelectPerson(person, idx, directors)">@p.FullName</div>
                                }
                            </div>
                        }
                    </div>
                }
                <button type="button" class="btn-add-row" @onclick="() => directors.Add(new PersonRow())">+ Lägg till regissör</button>
            </div>

            <div class="movie-form-field full-width">
                <label>Skådespelare</label>
                @for (int i = 0; i < cast.Count; i++)
                {
                    var idx = i;
                    <div class="person-search-row">
                        <div class="person-row-inputs">
                            <input type="text" placeholder="Sök person..."
                                   value="@cast[idx].DisplayName"
                                   @oninput="e => OnPersonSearchInput(e, idx, cast)"
                                   class="input-flex" />
                            <input type="text" placeholder="Rollnamn (valfritt)"
                                   @bind="cast[idx].CharacterName"
                                   class="input-flex" />
                            <input type="number" placeholder="Ordning"
                                   @bind="cast[idx].DisplayOrder"
                                   class="input-order-num" min="0" />
                            <button type="button" class="btn-remove-row" @onclick="() => cast.RemoveAt(idx)">✕</button>
                        </div>
                        @if (cast[idx].ShowDropdown && cast[idx].SearchResults.Count > 0)
                        {
                            <div class="person-search-result-dropdown">
                                @foreach (var p in cast[idx].SearchResults)
                                {
                                    var person = p;
                                    <div class="person-result-item" @onmousedown="() => SelectPerson(person, idx, cast)">@p.FullName</div>
                                }
                            </div>
                        }
                    </div>
                }
                <button type="button" class="btn-add-row" @onclick="() => cast.Add(new PersonRow())">+ Lägg till skådespelare</button>
            </div>

        </div>

        @if (!string.IsNullOrEmpty(submitError))
        {
            <p class="review-error">@submitError</p>
        }

        <div class="form-actions">
            <button class="btn-submit" @onclick="SubmitAsync" disabled="@submitting">
                @(submitting ? "Sparar..." : (Id.HasValue ? "Spara ändringar" : "Lägg till film"))
            </button>
            <a href="/admin/movies" class="form-cancel-link">Avbryt</a>
        </div>
    }
</div>

@code {
    // null = skapa ny film, int = redigera befintlig (från URL-parametern)
    [Parameter] public int? Id { get; set; }

    // Formulärfält
    private string title = "";
    private int releaseYear = DateTime.Now.Year;
    private int durationMinutes = 90;
    private string synopsis = "";
    private string? posterUrl;
    private string? trailerUrl;
    private string? language;
    private string? country;
    private decimal rentalPrice = 29.99m;
    private int stockQuantity = 0;
    private MovieAvailabilityStatus availabilityStatus = MovieAvailabilityStatus.Available;
    private bool isFeatured = false;

    // Produktionsbolag — sökbart fält med inline-skapande
    // (En film har max ett produktionsbolag, därav enstaka fält istället för lista)
    private string companySearchText = "";
    private int? selectedCompanyId;
    private bool showCompanyDropdown;
    private List<ProductionCompanyDto> filteredCompanies = [];
    private string? companyError;

    private HashSet<int> selectedGenreIds = []; // HashSet för O(1) toggle-koll
    private List<PersonRow> directors = [];
    private List<PersonRow> cast = [];

    private List<GenreDto> allGenres = [];
    private List<ProductionCompanyDto> companies = [];

    // Inline genre-skapande
    private string newGenreName = "";
    private string? genreError;

    private bool isLoading = true;
    private bool submitting;
    private bool showErrors; // true = visa valideringsfel för alla fält vid submit-försök
    private string? submitError;

    // "Touched"-flaggor per fält — valideringsfel visas direkt när fältet lämnas (onblur),
    // eller för alla fält på en gång om man försöker submitta med fel
    private bool _tTitle, _tYear, _tDuration, _tPrice, _tStock, _tSynopsis;
    private bool ShowTitle => showErrors || _tTitle;
    private bool ShowYear => showErrors || _tYear;
    private bool ShowDuration => showErrors || _tDuration;
    private bool ShowPrice => showErrors || _tPrice;
    private bool ShowStock => showErrors || _tStock;
    private bool ShowSynopsis => showErrors || _tSynopsis;

    protected override async Task OnInitializedAsync()
    {
        // Genres och produktionsbolag laddas alltid (behövs för dropdown-listorna)
        var genresTask = AdminClient.GetGenresAsync();           // GET api/genres
        var companiesTask = AdminClient.GetProductionCompaniesAsync(); // GET api/production-companies
        allGenres = await genresTask;
        companies = await companiesTask;

        if (Id.HasValue)
        {
            // Redigera-läge: ladda befintlig film och fyll formuläret
            var movie = await AdminClient.GetMovieByIdAsync(Id.Value); // GET api/admin/movies/{id}
            if (movie is not null)
            {
                title = movie.Title;
                releaseYear = movie.ReleaseYear;
                durationMinutes = movie.DurationMinutes;
                synopsis = movie.Synopsis ?? "";
                posterUrl = movie.PosterUrl;
                trailerUrl = movie.TrailerUrl;
                rentalPrice = movie.RentalPrice;
                availabilityStatus = Enum.TryParse<MovieAvailabilityStatus>(movie.AvailabilityStatus, out var s) ? s : MovieAvailabilityStatus.Available;
                stockQuantity = movie.StockQuantity;
                isFeatured = movie.IsFeatured;
                language = movie.Language;
                country = movie.Country;
                selectedCompanyId = movie.ProductionCompanyId;
                // Slå upp bolagsnamnet från den redan laddade companies-listan
                companySearchText = companies.FirstOrDefault(c => c.Id == movie.ProductionCompanyId)?.Name ?? "";
                // Matcha genres på namn (API returnerar namn, inte ID:n)
                selectedGenreIds = allGenres
                    .Where(g => movie.Genres.Contains(g.Name))
                    .Select(g => g.Id)
                    .ToHashSet();
                directors = movie.Directors.Select(d => new PersonRow { PersonId = d.PersonId, DisplayName = d.FullName }).ToList();
                cast = movie.Cast.Select(c => new PersonRow { PersonId = c.PersonId, DisplayName = c.FullName, CharacterName = c.CharacterName, DisplayOrder = c.DisplayOrder }).ToList();
            }
        }

        isLoading = false;
    }

    // Togglar en genre — HashSet.Add returnerar false om den redan finns
    private void ToggleGenre(int genreId)
    {
        if (!selectedGenreIds.Add(genreId))
            selectedGenreIds.Remove(genreId);
    }

    // Hanterar personssökning med debounce (300ms) per rad.
    // Varje PersonRow har sin egen CancellationTokenSource — föregående sökning
    // avbryts innan en ny startar för att undvika race conditions.
    private async Task OnPersonSearchInput(ChangeEventArgs e, int idx, List<PersonRow> rows)
    {
        var term = e.Value?.ToString() ?? "";
        rows[idx].DisplayName = term;
        rows[idx].PersonId = null; // Rensa valt person-ID när texten ändras

        // Avbryt och kassera eventuell pågående debounce för denna rad
        rows[idx].Debounce?.Cancel();
        rows[idx].Debounce?.Dispose();
        rows[idx].Debounce = new CancellationTokenSource();
        var token = rows[idx].Debounce.Token;
        try
        {
            await Task.Delay(300, token); // Vänta 300ms — avbryts om ny knapptryckning sker
            if (!string.IsNullOrWhiteSpace(term))
            {
                rows[idx].SearchResults = await AdminClient.GetPersonsAsync(term); // GET api/persons?search=...
                rows[idx].ShowDropdown = true;
            }
            else
            {
                rows[idx].SearchResults = [];
                rows[idx].ShowDropdown = false;
            }
        }
        catch (TaskCanceledException) { } // Debounce avbröts — ignorera
    }

    private void SelectPerson(PersonDto person, int idx, List<PersonRow> rows)
    {
        rows[idx].PersonId = person.Id;
        rows[idx].DisplayName = person.FullName;
        rows[idx].ShowDropdown = false;
        rows[idx].SearchResults = [];
    }

    private async Task SubmitAsync()
    {
        showErrors = true;
        int currentYear = DateTime.Now.Year;
        bool hasErrors =
            string.IsNullOrWhiteSpace(title) ||
            string.IsNullOrWhiteSpace(synopsis) ||
            releaseYear < 1888 || releaseYear > currentYear ||
            durationMinutes < 1 || durationMinutes > 600 ||
            rentalPrice < 0.01m || rentalPrice > 999.99m ||
            stockQuantity < 0 || stockQuantity > 10000;
        if (hasErrors) return;

        submitting = true;
        submitError = null;
        try
        {
            // Bygg credits-listan från regissörer och skådespelare som har ett valt PersonId
            // (rader utan valt person ignoreras — de är tomma söktextfält)
            var credits = new List<CreateMovieCreditDto>();
            foreach (var d in directors.Where(d => d.PersonId.HasValue))
                credits.Add(new CreateMovieCreditDto { PersonId = d.PersonId!.Value, Role = CreditRole.Director });
            foreach (var c in cast.Where(c => c.PersonId.HasValue))
                credits.Add(new CreateMovieCreditDto { PersonId = c.PersonId!.Value, Role = CreditRole.Actor, CharacterName = c.CharacterName, DisplayOrder = c.DisplayOrder });

            int? companyId = selectedCompanyId;

            if (Id.HasValue)
            {
                // PUT api/admin/movies/{id} — uppdatera befintlig film
                var dto = new UpdateMovieDto
                {
                    Id = Id.Value, Title = title, Synopsis = synopsis, ReleaseYear = releaseYear,
                    DurationMinutes = durationMinutes, RentalPrice = rentalPrice, PosterUrl = posterUrl,
                    TrailerUrl = trailerUrl, Language = language, Country = country,
                    ProductionCompanyId = companyId, AvailabilityStatus = availabilityStatus,
                    StockQuantity = stockQuantity, IsFeatured = isFeatured,
                    GenreIds = selectedGenreIds.ToList(), Credits = credits
                };
                var result = await AdminClient.UpdateMovieAsync(Id.Value, dto);
                if (result is not null) Navigation.NavigateTo("/admin/movies");
                else submitError = "Kunde inte uppdatera filmen. Kontrollera att alla ID:n är giltiga.";
            }
            else
            {
                // POST api/admin/movies — skapa ny film
                var dto = new CreateMovieDto
                {
                    Title = title, Synopsis = synopsis, ReleaseYear = releaseYear,
                    DurationMinutes = durationMinutes, RentalPrice = rentalPrice, PosterUrl = posterUrl,
                    TrailerUrl = trailerUrl, Language = language, Country = country,
                    ProductionCompanyId = companyId, AvailabilityStatus = availabilityStatus,
                    StockQuantity = stockQuantity, IsFeatured = isFeatured,
                    GenreIds = selectedGenreIds.ToList(), Credits = credits
                };
                var result = await AdminClient.CreateMovieAsync(dto);
                if (result is not null) Navigation.NavigateTo("/admin/movies");
                else submitError = "Kunde inte skapa filmen. Kontrollera att alla ID:n är giltiga.";
            }
        }
        catch (HttpRequestException ex)
        {
            submitError = $"Serverfel: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }

    // Filtrerar produktionsbolag client-side baserat på inmatat söktext
    private void OnCompanyInput(ChangeEventArgs e)
    {
        companySearchText = e.Value?.ToString() ?? "";
        selectedCompanyId = null; // Rensa valt bolag när texten ändras
        showCompanyDropdown = true;
        filteredCompanies = string.IsNullOrWhiteSpace(companySearchText)
            ? []
            : companies.Where(c => c.Name.Contains(companySearchText, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void SelectCompany(ProductionCompanyDto company)
    {
        selectedCompanyId = company.Id;
        companySearchText = company.Name;
        showCompanyDropdown = false;
        filteredCompanies = [];
    }

    private void ClearCompany()
    {
        selectedCompanyId = null;
        companySearchText = "";
        showCompanyDropdown = false;
        filteredCompanies = [];
    }

    // POST api/production-companies — skapar bolag och väljer det direkt
    private async Task CreateCompanyAsync()
    {
        companyError = null;
        showCompanyDropdown = false;
        var created = await AdminClient.CreateProductionCompanyAsync(companySearchText.Trim());
        if (created is not null)
        {
            companies.Add(created);
            companies = [.. companies.OrderBy(c => c.Name)]; // Håll listan sorterad
            SelectCompany(created);
        }
        else
        {
            companyError = $"Kunde inte skapa produktionsbolaget. Det kanske redan finns.";
        }
    }

    // POST api/genres — skapar genre och markerar den som vald direkt
    private async Task CreateGenreAsync()
    {
        genreError = null;
        var name = newGenreName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        var created = await AdminClient.CreateGenreAsync(name);
        if (created is not null)
        {
            allGenres.Add(created);
            allGenres = [.. allGenres.OrderBy(g => g.Name)]; // Håll listan sorterad
            selectedGenreIds.Add(created.Id);
            newGenreName = "";
        }
        else
        {
            genreError = $"Kunde inte lägga till genre. Den kanske redan finns.";
        }
    }

    // IDisposable: rensar alla CancellationTokenSource när komponenten tas bort
    // för att förhindra att pågående debounce-Tasks försöker uppdatera UI efter nedmontering
    public void Dispose()
    {
        foreach (var row in directors.Concat(cast))
        {
            row.Debounce?.Cancel();
            row.Debounce?.Dispose();
        }
    }

    // Intern klass som representerar en rad i regissör/skådespelare-listan
    private class PersonRow
    {
        public int? PersonId { get; set; }       // null = ingen matchad person (bara text inmatat)
        public string DisplayName { get; set; } = "";
        public string? CharacterName { get; set; } // Skådespelarens rollnamn (valfritt)
        public int DisplayOrder { get; set; } = 0; // Sorteringsordning i credits
        public bool ShowDropdown { get; set; }
        public List<PersonDto> SearchResults { get; set; } = [];
        public CancellationTokenSource? Debounce { get; set; } // Per-rad debounce för sökning
    }
}
