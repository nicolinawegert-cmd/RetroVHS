@using RetroVHS.Shared.DTOs.Auth
@using RetroVHS.Shared.DTOs.Movies
@inject IAuthClient AuthClient
@inject IMovieClient MovieClient
@inject ICartClient CartClient
@inject CartState CartState
@inject NavigationManager Navigation
@implements IDisposable

<header class="site-header">
    <div class="header-brand">
        <a href="/"><img src="design/logo.png" alt="RetroVHS" class="header-logo" /></a>
    </div>

    <div class="header-search">
        <div class="search-container">
            <input type="text"
                   class="search-input"
                   placeholder="Sök filmer..."
                   @bind="searchText"
                   @bind:event="oninput"
                   @bind:after="OnSearchInputAsync"
                   @onfocus="OnSearchFocus"
                   @onblur="OnSearchBlur" />

            @if (showResults && searchResults.Count > 0)
            {
                <div class="search-results">
                    @foreach (var movie in searchResults)
                    {
                        <div class="search-result-item" @onmousedown="() => SelectMovie(movie)">
                            <span class="result-title">@movie.Title</span>
                            <span class="result-year">(@movie.ReleaseYear)</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="header-auth">
        <AuthorizeView Context="authContext">
            <Authorized>
                <AuthorizeView Roles="Admin" Context="adminCartCtx">
                    <NotAuthorized>
                <a class="header-cart-link" href="/cart" title="Varukorg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                    @if (CartState.ItemCount > 0)
                    {
                        <span class="cart-badge">@CartState.ItemCount</span>
                    }
                </a>
                    </NotAuthorized>
                </AuthorizeView>
                <div class="user-menu-wrapper">
                    <button class="user-menu-btn" @onclick="ToggleUserMenu">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                        </svg>
                        <span>@authContext.User.FindFirst("firstName")?.Value</span>
                        <svg class="user-menu-chevron @(showUserMenu ? "open" : "")" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9" />
                        </svg>
                    </button>
                    @if (showUserMenu)
                    {
                        <div class="menu-backdrop" @onclick="CloseUserMenu"></div>
                        <div class="user-menu-dropdown">
                            <a class="user-menu-item" href="/profile" @onclick="CloseUserMenu">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                </svg>
                                Visa profil
                            </a>
                            <AuthorizeView Roles="Admin" Context="adminCtx">
                                <Authorized>
                                    <a class="user-menu-item" href="/admin/users" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                        </svg>
                                        Användarlistan
                                    </a>
                                    <a class="user-menu-item" href="/admin/movies" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 2v20M17 2v20M2 12h20M2 7h5M17 7h5M2 17h5M17 17h5"/>
                                        </svg>
                                        Filmlistan
                                    </a>
                                    <div class="user-menu-divider"></div>
                                    <a class="user-menu-item" href="/admin" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                        </svg>
                                        Admin
                                    </a>
                                </Authorized>
                                <NotAuthorized>
                                    <a class="user-menu-item" href="/my-reviews" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                        </svg>
                                        Mina recensioner
                                    </a>
                                    <a class="user-menu-item" href="/cart" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                                        </svg>
                                        Varukorg
                                    </a>
                                    <a class="user-menu-item" href="/my-orders" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-4 0v2" /><line x1="12" y1="12" x2="12" y2="16" /><line x1="10" y1="14" x2="14" y2="14" />
                                        </svg>
                                        Mina beställningar
                                    </a>
                                    <a class="user-menu-item" href="/wishlist" @onclick="CloseUserMenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                        </svg>
                                        Min önskelista
                                    </a>
                                </NotAuthorized>
                            </AuthorizeView>
                            <div class="user-menu-divider"></div>
                            <button class="user-menu-item logout" @onclick="HandleLogoutAsync">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" />
                                </svg>
                                Logga ut
                            </button>
                        </div>
                    }
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="auth-buttons">
                    <div class="login-wrapper">
                        <button class="btn-login" @onclick="ToggleLoginForm">Logga in</button>

                        @if (showLoginForm)
                        {
                            <div class="login-dropdown">
                                <EditForm Model="loginRequest" OnValidSubmit="HandleLoginAsync">
                                    <DataAnnotationsValidator />
                                    <div class="login-field">
                                        <input type="email"
                                               placeholder="E-post"
                                               @bind="loginRequest.Email" />
                                    </div>
                                    <div class="login-field password-field">
                                        <div class="password-input-wrapper">
                                            <input type="@(showLoginPassword ? "text" : "password")"
                                                   placeholder="Lösenord"
                                                   @bind="loginRequest.Password" />
                                            <button type="button" class="btn-eye" @onclick="() => showLoginPassword = !showLoginPassword"
                                                    tabindex="-1">
                                                @if (showLoginPassword)
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                                }
                                                else
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                                }
                                            </button>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(loginError))
                                    {
                                        <div class="login-error">@loginError</div>
                                    }
                                    <button type="submit" class="btn-submit" disabled="@isLoggingIn">
                                        @(isLoggingIn ? "Loggar in..." : "Logga in")
                                    </button>
                                </EditForm>
                            </div>
                        }
                    </div>

                    <div class="login-wrapper">
                        <button class="btn-register" @onclick="ToggleRegisterForm">Registrera</button>

                        @if (showRegisterForm)
                        {
                            <div class="login-dropdown register-dropdown">
                                <EditForm Model="registerRequest" OnValidSubmit="HandleRegisterAsync">
                                    <DataAnnotationsValidator />
                                    <div class="login-field">
                                        <InputText placeholder="Förnamn"
                                                   @bind-Value="registerRequest.FirstName" />
                                        <ValidationMessage For="() => registerRequest.FirstName" />
                                    </div>
                                    <div class="login-field">
                                        <InputText placeholder="Efternamn"
                                                   @bind-Value="registerRequest.LastName" />
                                        <ValidationMessage For="() => registerRequest.LastName" />
                                    </div>
                                    <div class="login-field">
                                        <InputText placeholder="Nickname (valfritt)"
                                                   @bind-Value="registerRequest.Nickname" />
                                    </div>
                                    <div class="login-field">
                                        <InputText type="email"
                                                   placeholder="E-post"
                                                   @bind-Value="registerRequest.Email" />
                                        <ValidationMessage For="() => registerRequest.Email" />
                                    </div>
                                    <div class="login-field password-field">
                                        <div class="password-input-wrapper">
                                            <InputText type="@(showRegPassword ? "text" : "password")"
                                                       placeholder="Lösenord"
                                                       @bind-Value="registerRequest.Password" />
                                            <button type="button" class="btn-eye" @onclick="() => showRegPassword = !showRegPassword"
                                                    tabindex="-1">
                                                @if (showRegPassword)
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                                }
                                                else
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                                }
                                            </button>
                                        </div>
                                        <ValidationMessage For="() => registerRequest.Password" />
                                    </div>
                                    <div class="login-field password-field">
                                        <div class="password-input-wrapper">
                                            <InputText type="@(showRegConfirmPassword ? "text" : "password")"
                                                       placeholder="Bekräfta lösenord"
                                                       @bind-Value="registerRequest.ConfirmPassword" />
                                            <button type="button" class="btn-eye" @onclick="() => showRegConfirmPassword = !showRegConfirmPassword"
                                                    tabindex="-1">
                                                @if (showRegConfirmPassword)
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                                }
                                                else
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                                }
                                            </button>
                                        </div>
                                        <ValidationMessage For="() => registerRequest.ConfirmPassword" />
                                    </div>
                                    @if (!string.IsNullOrEmpty(registerError))
                                    {
                                        <div class="login-error">@registerError</div>
                                    }
                                    <button type="submit" class="btn-submit" disabled="@isRegistering">
                                        @(isRegistering ? "Registrerar..." : "Skapa konto")
                                    </button>
                                </EditForm>
                            </div>
                        }
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

@code {
    private string searchText = string.Empty;
    private List<MovieListDto> searchResults = [];
    private bool showResults;
    private CancellationTokenSource? _debounceTokenSource;

    private bool showUserMenu;

    private void ToggleUserMenu() => showUserMenu = !showUserMenu;
    private void CloseUserMenu() => showUserMenu = false;

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += StateHasChanged;
        await LoadCartCount();
    }

    private async Task LoadCartCount()
    {
        try
        {
            var cart = await CartClient.GetCartAsync();
            CartState.SetCount(cart?.TotalItems ?? 0);
        }
        catch
        {
            CartState.SetCount(0);
        }
    }

    private LoginRequestDto loginRequest = new();
    private bool showLoginForm;
    private bool isLoggingIn;
    private string? loginError;

    private RegisterRequestDto registerRequest = new();
    private bool showRegisterForm;
    private bool isRegistering;
    private string? registerError;

    private bool showLoginPassword;
    private bool showRegPassword;
    private bool showRegConfirmPassword;

    private async Task OnSearchInputAsync()
    {
        _debounceTokenSource?.Cancel();
        _debounceTokenSource = new CancellationTokenSource();
        var token = _debounceTokenSource.Token;

        if (string.IsNullOrWhiteSpace(searchText))
        {
            searchResults = [];
            showResults = false;
            return;
        }

        try
        {
            await Task.Delay(300, token);
            searchResults = await MovieClient.SearchMoviesAsync(searchText);
            showResults = searchResults.Count > 0;
        }
        catch (TaskCanceledException)
        {
            // Debounce avbruten, ignorera
        }
    }

    private void OnSearchFocus()
    {
        if (searchResults.Count > 0)
        {
            showResults = true;
        }
    }

    private async Task OnSearchBlur()
    {
        // Kort fördröjning så att mousedown på resultat hinner triggas före blur
        await Task.Delay(200);
        showResults = false;
    }

    private void SelectMovie(MovieListDto movie)
    {
        searchText = string.Empty;
        searchResults = [];
        showResults = false;
        Navigation.NavigateTo($"/movie/{movie.Id}");
    }

    private void ToggleLoginForm()
    {
        showLoginForm = !showLoginForm;
        showRegisterForm = false;
        loginError = null;
        showLoginPassword = false;
    }

    private void ToggleRegisterForm()
    {
        showRegisterForm = !showRegisterForm;
        showLoginForm = false;
        registerError = null;
        showRegPassword = false;
        showRegConfirmPassword = false;
    }

    private async Task HandleLoginAsync()
    {
        isLoggingIn = true;
        loginError = null;

        var result = await AuthClient.LoginAsync(loginRequest);

        if (result.Succeeded)
        {
            showLoginForm = false;
            loginRequest = new();
            await LoadCartCount();
        }
        else
        {
            loginError = result.Message is { Length: > 0 }
                ? result.Message
                : "Inloggning misslyckades.";
        }

        isLoggingIn = false;
    }

    private async Task HandleLogoutAsync()
    {
        showUserMenu = false;
        await AuthClient.LogoutAsync();
        Navigation.NavigateTo("/", true);
    }

    private async Task HandleRegisterAsync()
    {
        isRegistering = true;
        registerError = null;

        var result = await AuthClient.RegisterAsync(registerRequest);

        if (result.Succeeded)
        {
            showRegisterForm = false;
            registerRequest = new();
        }
        else
        {
            registerError = result.Errors.Count > 0
                ? string.Join(" ", result.Errors)
                : result.Message is { Length: > 0 }
                    ? result.Message
                    : "Registrering misslyckades.";
        }

        isRegistering = false;
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
        _debounceTokenSource?.Dispose();
    }
}
