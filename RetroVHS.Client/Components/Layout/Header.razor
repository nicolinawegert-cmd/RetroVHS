@inject ICartClient CartClient
@inject CartState CartState
@implements IDisposable

<header class="site-header">
<div class="header-inner">
    <div class="header-brand">
        <a href="/"><img src="design/logo.png" alt="RetroVHS" class="header-logo" /></a>
    </div>

    <HeaderSearch IsOpen="@showSearch" OnClose="() => showSearch = false" />

    <div class="header-auth">
        <button class="search-toggle-btn" @onclick="ToggleSearch" title="@(showSearch ? "Stäng sök" : "Sök")">
            @if (showSearch)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            }
        </button>

        <AuthorizeView Context="authContext">
            <Authorized>
                <AuthorizeView Roles="Admin">
                    <NotAuthorized>
                        <a class="header-cart-link" href="/cart" title="Varukorg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                            </svg>
                            @if (CartState.ItemCount > 0)
                            {
                                <span class="cart-badge">@CartState.ItemCount</span>
                            }
                        </a>
                    </NotAuthorized>
                </AuthorizeView>

                <UserMenu FirstName="@(authContext.User.FindFirst("firstName")?.Value ?? "")" />
            </Authorized>
            <NotAuthorized>
                <AuthButtons OnLoginSuccess="LoadCartCount" />
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>
</header>

@code {
    private bool showSearch;

    private void ToggleSearch() => showSearch = !showSearch;

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += StateHasChanged;
        await LoadCartCount();
    }

    private async Task LoadCartCount()
    {
        try
        {
            var cart = await CartClient.GetCartAsync();
            CartState.SetCount(cart?.TotalItems ?? 0);
        }
        catch
        {
            CartState.SetCount(0);
        }
    }

    public void Dispose() => CartState.OnChange -= StateHasChanged;
}
